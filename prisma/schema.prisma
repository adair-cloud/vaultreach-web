generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  // Google OAuth returns this field — must be present or PrismaAdapter throws
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String     @id @default(cuid())
  name                  String?
  email                 String?    @unique
  emailVerified         DateTime?
  image                 String?
  appPassword           String?    @db.Text
  
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  
  accounts              Account[]
  sessions              Session[]
  campaigns             Campaign[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Campaign {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                String    @default("inactive") // active, inactive
  targetIndustry        String
  targetTitles          String
  employeeRange         String
  targetLocations       String
  websiteUrl            String?
  // AI Brain settings — stored in their own columns, not hijacking ICP fields
  tone                  String    @default("professional")
  rules                 String?   @db.Text
  // Scheduling Settings
  timezone              String    @default("America/New_York")
  sendWindowStart       Int       @default(9)  // 9 AM
  sendWindowEnd         Int       @default(17) // 5 PM
  sendDays              String    @default("1,2,3,4,5") // Mon-Fri
  // Worker heartbeat — updated by the Python worker each cycle
  lastPing              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  analytics             Analytics[]
  replies               Reply[]
  leads                 Lead[]
}

model Analytics {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  emailsSent  Int      @default(0)
  replies     Int      @default(0)
  meetings    Int      @default(0)
}

model Reply {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  senderName  String
  senderRole  String?  // e.g. "CEO at Horizon Roofers"
  preview     String   @db.Text
  score       String   @default("Warm") // Hot | Warm | Cold
  receivedAt  DateTime @default(now())
}

enum LeadStatus {
  COLD
  FOLLOW_UP
  REPLIED
  BOUNCED
}

model Lead {
  id            String     @id @default(uuid())
  campaignId    String
  campaign      Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email         String
  status        LeadStatus @default(COLD)
  stepIndex     Int        @default(1)
  lastContacted DateTime?
}
